ZMK_BASE_LAYER(Night,
//╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
    &kp B         &kp F         &kp L         &kp K         &kp Q       ,   &kp P         &kp G         &kp O         &kp U         &dot_morph  ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    &hml LGUI N   &hml LALT S   &hml LCTRL H  &hml LSHFT T  &kp M       ,   &kp Y         &hmr RSHFT C  &hmr RCTRL A  &hmr LALT E   &hmr LGUI I ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    &kp X         &kp V         &kp J         &kp D         &kp Z       ,   &kp SQT       &kp W         &qexcl        &kp MINUS     &comma_morph,
//╰─────────────┼─────────────┴─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┴───────────────────────────╯
                                &kp ESC      &lt NAV R     &lt NUM BSPC,   &lt FN RET    &lt_spc SYM 0  &kp TAB
//                            ╰─────────────┴─────────────┴─────────────╯ ╰─────────────┴─────────────┴─────────────╯
)
