ZMK_BASE_LAYER(Nav,
//╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
    &kp RET       &kp SPACE     &kp TAB       NAV_BSPC      _CUT        ,   _CUT          NAV_BSPC      _UNDO         _REDO         NAV_DEL     ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    &sk LGUI      &sk LALT      &sk LCTRL     &sk LSHFT     _COPY       ,   _COPY         NAV_LEFT      NAV_UP        NAV_DOWN      NAV_RIGHT   ,
//├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
    FIND          &select_line  &select_word  &select_all   _PASTE      ,   _PASTE        ___           &kp PG_UP     &kp PG_DN     ___         ,
//╰─────────────┼─────────────┴─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┴───────────────────────────╯
                                ___           ___           ___         ,   &select_line  &select_word  &extend_word
